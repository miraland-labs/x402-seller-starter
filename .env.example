# Public URL of this seller API (no trailing slash) — used in x402 Payment Required `resource.url`.
# Examples: http://127.0.0.1:3000 (local; match BIND_ADDR / how you curl)
#           https://api.example.com (production; URL clients use, often behind reverse proxy)
SELLER_PUBLIC_BASE_URL=http://127.0.0.1:3000

# pr402 base URL (no trailing slash)
FACILITATOR_BASE_URL=https://preview.pr402.signer-payer.me
#
# Find X402_PAY_TO: `cargo run --example find_payto` (uses MERCHANT_WALLET + GET /supported).
# Optional: SELLER_FETCH_ONBOARD_TX=1 for unsigned provisioning tx JSON (not needed for payTo).
#
# Merchant Solana pubkey (base58). Alias: SELLER_WALLET.
MERCHANT_WALLET=<your_base58_merchant_pubkey>

# Optional copy (values with spaces must be double-quoted — dotenvy parses like sh)
SELLER_RESOURCE_DESCRIPTION="Example premium API (x402 seller starter)"
SELLER_RESOURCE_MIME=application/json
SELLER_FREE_PATH=/api/free
SELLER_PAID_PATH=/api/premium
BIND_ADDR=127.0.0.1:3000

# --- accepts[]: choose ONE style ---

# (A) Full accepts JSON (for exact rail, payTo = vault PDA — same value `find_payto` prints):
# X402_ACCEPTS_JSON='[{"scheme":"v2:solana:exact","network":"solana:...","asset":"...","amount":"10000","payTo":"<VAULT_FROM_FIND_PAYTO>","maxTimeoutSeconds":600,"extra":{...}}]'

# (B) Or discrete vars below + REQUIRED `extra` for pr402 exact verify (copy from `find_payto` output):
X402_SCHEME=v2:solana:exact
# Mainnet: solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# Devnet: solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
# USDC (USD Coin) for Mainnet
# X402_ASSET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDC (USD Coin) for Devnet
X402_ASSET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# $0.01usdc(1 cent)
X402_AMOUNT=10000
# Exact rail: vault PDA = output of `cargo run --example find_payto` (GET /supported + MERCHANT_WALLET).
X402_PAY_TO=<RUN_FIND_PAYTO_OR_PASTE_VAULT_PDA_HERE>
X402_MAX_TIMEOUT_SECONDS=600

# Preview devnet `exact` extra (refresh if facilitator changes — or run `cargo run --example find_payto`):
X402_ACCEPTS_EXTRA_JSON='{"beneficiary":null,"configAddress":"2qPZcbD62QXVNmv3h1aSwACN3cfKbm5VQgbVSkxjp8Ed","feeBps":"100","feePayer":"FaciLFwHjbW9V1PtF3vAweL1K1hgin9mvXNXatEQKJdu","merchantWallet":null,"minFeeAmount":"10000","minFeeAmountSol":"200000","programId":"u5kv5wqJqHVLbdp9Vrd5pBsFswJ9MzpotoaxYNn39MN"}'

RUST_LOG=info
